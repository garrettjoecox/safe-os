#!/usr/bin/env bash
# Sets the parent escape-hatch password. Stores an argon2id hash, never the password.
set -euo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "Must run as root." >&2
  exit 1
fi

read -rsp "New parent password: " pw1; echo
read -rsp "Confirm: "             pw2; echo
[[ "$pw1" == "$pw2" ]] || { echo "Mismatch." >&2; exit 1; }
[[ -n "$pw1" ]] || { echo "Empty." >&2; exit 1; }

salt=$(head -c 16 /dev/urandom | base64)
hash=$(printf '%s' "$pw1" | argon2 "$salt" -id -t 3 -m 16 -p 2 -e)

install -d -m 0755 -o root -g root /etc/safe-os
umask 077
printf '%s\n%s\n' "$salt" "$hash" > /etc/safe-os/parent.hash
chmod 0600 /etc/safe-os/parent.hash
chown root:root /etc/safe-os/parent.hash

unset pw1 pw2
echo "Parent password set."
