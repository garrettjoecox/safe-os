<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>

  <!-- Reserve the tint2 dock strip so maximized apps never sit under it.
       Matches panel_size height in config/tint2/tint2rc and panel_position=bottom. -->
  <margins>
    <top>0</top>
    <bottom>96</bottom>
    <left>0</left>
    <right>0</right>
  </margins>

  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <focusLast>yes</focusLast>
    <underMouse>no</underMouse>
    <focusDelay>200</focusDelay>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>

  <placement>
    <policy>Smart</policy>
    <center>yes</center>
  </placement>

  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>yes</animateIconify>
  </theme>

  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
    <names><name>kiosk</name></names>
    <popupTime>0</popupTime>
  </desktops>

  <resize>
    <drawContents>yes</drawContents>
    <popupShow>Never</popupShow>
  </resize>

  <!-- Only this single binding survives. Everything else (Alt+Tab, Super, F11,
       Ctrl+Alt+arrows, etc.) is intentionally absent. -->
  <keyboard>
    <chainQuitKey>C-g</chainQuitKey>
    <keybind key="C-A-S-p">
      <action name="Execute">
        <command>/usr/local/bin/parent-mode</command>
      </action>
    </keybind>
  </keyboard>

  <!-- Empty mouse section: no desktop right-click menu, no middle-click, no
       drag-to-resize from window borders the kid would otherwise see. -->
  <mouse>
    <dragThreshold>8</dragThreshold>
    <doubleClickTime>200</doubleClickTime>
    <screenEdgeWarpTime>0</screenEdgeWarpTime>
    <screenEdgeWarpMouse>false</screenEdgeWarpMouse>
    <context name="Frame"/>
    <context name="Titlebar"/>
    <context name="Top"/>
    <context name="Left"/>
    <context name="Right"/>
    <context name="Bottom"/>
    <context name="BLCorner"/>
    <context name="BRCorner"/>
    <context name="TLCorner"/>
    <context name="TRCorner"/>
    <context name="Client"/>
    <context name="Icon"/>
    <context name="AllDesktops"/>
    <context name="Shade"/>
    <context name="Iconify"/>
    <context name="Maximize"/>
    <context name="Close"/>
    <context name="Desktop"/>
    <context name="Root"/>
    <context name="MoveResize"/>
  </mouse>

  <!-- All app windows open maximized and undecorated; no titlebar = no close
       button to puzzle over, and no way to drag a window off-screen. -->
  <applications>
    <application class="*">
      <decor>no</decor>
      <maximized>yes</maximized>
      <fullscreen>no</fullscreen>
      <focus>yes</focus>
      <layer>normal</layer>
    </application>
    <application name="tint2">
      <decor>no</decor>
      <maximized>no</maximized>
      <layer>above</layer>
      <skip_pager>yes</skip_pager>
      <skip_taskbar>yes</skip_taskbar>
    </application>
  </applications>
</openbox_config>
